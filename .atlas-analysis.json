    "POST /api/proofs/generate - Generate payment proof",
    "GET /api/anchors/countries - Get supported countries",
    "GET /api/anchors/catalog - Query anchor catalog",
    "POST /api/anchors/capabilities/refresh - Refresh anchor capabilities",
    "GET /api/anchors/diagnostics - Get anchor system diagnostics",
    "GET /api/health - API health check"
